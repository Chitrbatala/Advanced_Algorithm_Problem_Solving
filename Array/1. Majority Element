class Solution {
    public int majorityElement(int[] nums) {
        int n = nums.length;
        int votes = 1;
        int majority = nums[0];

        for (int i = 1; i < n; i++) {
            if (votes == 0) {
                majority = nums[i];
                votes++;
            } else if (nums[i] == majority) {
                votes++;
            } else {
                votes--;
            }
        }
        return majority;
    }
}

