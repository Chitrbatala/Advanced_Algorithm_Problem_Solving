class Solution {
    public List<Integer> frequencyCount(int[] arr) {
        int n = arr.length;
        int[] ans = new int[n];
        
        for (int i = 0; i < n; i++) {
            int index = arr[i] - 1;
            ans[index]++;
        }
        
        ArrayList<Integer> res = new ArrayList<>();
        
        for (int num : ans) {
            res.add(num);
        }
        return res;
    }
}
