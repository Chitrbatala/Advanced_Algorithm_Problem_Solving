class Solution {
    public boolean hasTripletSum(int arr[], int target) {
        // code Here
        int n = arr.length;
        
        Arrays.sort(arr);
        
        
        for (int i = 0; i < n - 2; i++) {
            int fixed = arr[i];
            int l = i + 1;
            int h = n - 1;
            
            while (l < h) {
                int currSum = fixed + arr[l] + arr[h];
                
                if (currSum == target) {
                    return true;
                } else if (currSum < target) {
                    l++;
                } else {
                    h--;
                }
            }
        }
        return false;
    }
}
