public class Solution {
    public int solve(int[] A, int B) {
        Arrays.sort(A);
        
        B = Math.abs(B);
        
        int i = 0;
        int j = 1;
        
        while (j < A.length) {
            int diff = A[j] - A[i];
            
            if (diff == B && i != j) {
                return 1;
            } else if (diff < B) {
                j++;
            } else {
                i++;
            }
            
            if (i == j) {
                j++;
            }
        }
        return 0;
    }
}
