class Solution {
    public static ArrayList<Integer> findClosestPair(int arr1[], int arr2[], int x) {
        // code here
        int n = arr1.length;
        int m = arr2.length;
        
        ArrayList<Integer> res = new ArrayList<>();
        
        int bestA = arr1[0];
        int bestB = arr2[m - 1];
        
        int bestDiff = Math.abs((bestA + bestB) - x);
        
        int i = 0;
        int j = m - 1;
        
        while (i < n && j >= 0) {
            int currSum = arr1[i] + arr2[j];
            int currDiff = Math.abs(currSum - x);
            
            if (currDiff < bestDiff) {
                bestDiff = currDiff;
                bestA = arr1[i];
                bestB = arr2[j];
            }
            
            if (currSum > x) {
                j--;
            } else if (currSum < x) {
                i++;
            } else {
                break;
            }
        }
        
        res.add(bestA);
        res.add(bestB);

        return res;
    }
}
