class Solution {
    public int threeSumClosest(int[] nums, int target) {
        int n = nums.length;
        Arrays.sort(nums);

        int sum = nums[0] + nums[1] + nums[2];

        for (int i = 0; i < n; i++) {
            int l = i + 1;
            int h = n - 1;

            while (l < h) {
                int currSum = nums[i] + nums[l] + nums[h];

                if (Math.abs(target - currSum) < Math.abs(target - sum)) {
                    sum = currSum;
                }
                if (currSum < target) {
                    l++;
                } else if (currSum > target) {
                    h--;
                } else {
                    return currSum;
                }
            }
        }
        return sum;
    }
}
