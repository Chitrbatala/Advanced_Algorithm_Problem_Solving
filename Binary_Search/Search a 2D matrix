class Solution {
    public boolean searchMatrix(int[][] matrix, int target) {
        int m = matrix.length;
        int n = matrix[0].length;

        for (int i = 0; i < m; i++) {
            int l = 0;
            int r = n - 1;

            while (l <= r) {
                int mid = l + (r - l) / 2;

                if (matrix[i][mid] == target) {
                    return true;
                } else if (matrix[i][mid] < target) {
                    l++;
                } else {
                    r--;
                }
            }
        }
        return false;
    }
}
